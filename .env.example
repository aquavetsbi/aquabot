# ─── App ────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ─── WhatsApp ────────────────────────────────
# Provider: 'baileys' | 'twilio'
WHATSAPP_PROVIDER=baileys

# Baileys — carpeta donde persiste la sesión QR
BAILEYS_AUTH_FOLDER=./baileys-auth

# Twilio (dejar vacío hasta la migración)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+14155238886

# ─── Anthropic (Claude Vision) ───────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase ────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
# Service role key — NUNCA exponer en frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=aquabot-images

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379
