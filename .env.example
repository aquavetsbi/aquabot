# ─── App ────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ─── WhatsApp ────────────────────────────────
# Provider: 'baileys' | 'twilio'
WHATSAPP_PROVIDER=baileys

# Baileys — carpeta donde persiste la sesión QR
BAILEYS_AUTH_FOLDER=./baileys-auth

# Twilio (dejar vacío si usas Baileys)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+14155238886

# ─── Google Gemini (OCR + chat) ───────────────
# Clave de la API de Google AI Studio: https://aistudio.google.com/app/apikey
# Ambas variables deben tener el mismo valor:
#   GEMINI_API_KEY         → usado por el cliente de chat (@google/generative-ai)
#   GOOGLE_GENERATIVE_AI_API_KEY → usado por el cliente OCR (@ai-sdk/google)
GEMINI_API_KEY=AIza...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# Modelo para chat (evitar previews deprecados)
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ─── Supabase ────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
# Service role key — NUNCA exponer en frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=aquabot-images

# Opcional: auto-registra números desconocidos en esta organización (solo desarrollo)
# SUPABASE_DEFAULT_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379
